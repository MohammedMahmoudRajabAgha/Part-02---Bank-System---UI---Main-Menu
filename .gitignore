## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# Visual C++ cache files
*.VC.db
*.VC.opendb

# Visual Studio Installer
.vsconfig

# Logs
*.log

# Temporary files
*.tmp
*.temp

# IntelliSense
ipch/
*.ipch

# ReSharper
_ReSharper*/
*.DotSettings.user

# Visual Studio Code
.vscode/

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

# Test Results
TestResults/

# NuGet Packages
*.nupkg
packages/

# Windows thumbnails
Thumbs.db
Desktop.ini